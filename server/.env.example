# Copia este archivo a server/.env y ajusta los valores.
# La base de datos debe existir antes de migrar/restaurar.
DATABASE_URL=postgres://usuario:password@localhost:5432/lab
PORT=3000

# Secreto de sesión: genera uno propio (NO uses el de otra máquina).
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Autenticación: standalone = login local del propio sistema (lo normal).
AUTH_MODE=standalone

# Dirección fija por la que los equipos y celulares alcanzan este servidor.
# La usa el QR de la firma digital (ver "Firma digital y QR de verificación"
# en el README). Recomendable siempre; obligatoria si el servidor tiene más
# de una red activa a la vez.
# APP_URL=http://<IP-o-nombre-del-servidor>:3000

# ─────────────────────────────────────────────────────────────────────────
# Opcional — solo si algún día se conecta al login central del QMS (SSO).
# Con AUTH_MODE=standalone estas variables NO se usan.
# AUTH_MODE=sso
# OIDC_ISSUER=http://<host-keycloak>:8080/realms/qms
# SSO_URL=http://<host-keycloak>:8080
# SSO_REALM=qms
