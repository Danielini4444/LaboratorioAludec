DATABASE_URL=postgres://usuario:password@localhost:5432/lab
PORT=3000
# Genera uno propio: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Autenticación: standalone (login local) | sso (login central del QMS)
AUTH_MODE=standalone
OIDC_ISSUER=http://localhost:8080/realms/qms
SSO_URL=http://localhost:8080
SSO_REALM=qms

# Dirección fija por la que los teléfonos alcanzan este servidor, para el
# QR de firma digital (ver "Firma digital y QR de verificación" en el
# README). Necesaria si el servidor tiene más de una red activa a la vez;
# recomendable siempre, para no depender de la detección automática.
# APP_URL=http://<IP-o-nombre-del-servidor>:3000
