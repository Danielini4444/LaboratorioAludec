{
  "name": "lab",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm --prefix server run dev\" \"npm --prefix client run dev\"",
    "build": "npm --prefix client run build",
    "start": "npm --prefix server start",
    "migrate": "npm --prefix server run migrate",
    "seed": "npm --prefix server run seed",
    "restore": "node server/scripts/restore.js"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
